{
  "version": "0.2.0",
  "configurations": [
    {
      "name": ".NET API (HTTP)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "prepare: debug http",
      "program": "${workspaceFolder}/src/APITemplate/bin/Debug/net10.0/APITemplate.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/APITemplate",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5174",
        "ConnectionStrings__DefaultConnection": "Host=localhost;Port=5432;Database=apitemplate;Username=postgres;Password=postgres",
        "MongoDB__ConnectionString": "mongodb://localhost:27017",
        "MongoDB__DatabaseName": "apitemplate"
      },
      "console": "integratedTerminal"
    },
    {
      "name": ".NET API (HTTPS + HTTP)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "prepare: debug https",
      "program": "${workspaceFolder}/src/APITemplate/bin/Debug/net10.0/APITemplate.dll",
      "args": [],
      "cwd": "${workspaceFolder}/src/APITemplate",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "https://localhost:7289;http://localhost:5174",
        "ConnectionStrings__DefaultConnection": "Host=localhost;Port=5432;Database=apitemplate;Username=postgres;Password=postgres",
        "MongoDB__ConnectionString": "mongodb://localhost:27017",
        "MongoDB__DatabaseName": "apitemplate"
      },
      "console": "integratedTerminal"
    }
  ]
}
